# AI-Analyze 配置示例
# 复制此文件为 .env 并根据实际情况修改

# LLM 配置（可选，用于 AI 增强分析，基于 litellm 支持 100+ 提供商）
# OPENAI_API_KEY=your_api_key
# OPENAI_MODEL=openai/gpt-4
# 其他提供商示例：
#   OPENAI_MODEL=deepseek/deepseek-chat
#   OPENAI_MODEL=anthropic/claude-3-sonnet
#   OPENAI_MODEL=groq/llama3-70b-8192

# Serena 安装目录（可选，用于 Serena 后端）
# SERENA_DIR=/path/to/your/serena

# MCP 服务器端口（SSE 传输模式，默认 8000）
# MCP_SERVER_PORT=8000

# Redis 配置（可选，三级缓存 L3 层）
# REDIS_URL=redis://localhost:6379/0
